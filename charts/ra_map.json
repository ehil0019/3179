{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Australia Remoteness Areas (RA 2021)",
  "width": 800,
  "height": 600,

  "data": {
    "url": "data/ra_2021.geojson",
    "format": {"type": "geojson"}
  },

  "projection": {"type": "mercator"},

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 0.5
  },

  "encoding": {
    "color": {
      "field": "properties.ra_name_21",
      "type": "nominal",
      "title": "Remoteness Area"
    },
    "tooltip": [
      {"field": "properties.ra_name_21", "title": "Area"},
      {"field": "properties.ra_code_21", "title": "Code"}
    ]
  }
}
