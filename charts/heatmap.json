{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Heatmap of age-standardised death rates per 100,000 by cause of death and remoteness area, 2021-2023",
  "width": 240,
  "height": 210,
  "data": {
    "url": "data/heatmap_data.csv"
  },
  "encoding": {
    "y": {
      "field": "condition",
      "type": "nominal",
      "title": null,
      "sort": [
        "Coronary heart disease",
        "Dementia",
        "Cerebrovascular disease",
        "Lung cancer",
        "COPD",
        "Diabetes",
        "Colorectal cancer",
        "Heart failure",
        "Prostate cancer",
        "COVID-19",
        "Accidental falls",
        "Suicide",
        "Land transport accidents",
        "Kidney failure"
      ],
      "axis": {
        "labelFontSize": 11,
        "labelLimit": 200
      }
    },
    "x": {
      "field": "remoteness_area",
      "type": "nominal",
      "title": null,
      "sort": [
        "Major Cities",
        "Inner Regional",
        "Outer Regional",
        "Remote",
        "Very Remote"
      ],
      "axis": {
        "labelFontSize": 11,
        "labelAngle": -25
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "condition": {
            "test": "!isValid(datum.age_std_rate) || datum.age_std_rate === 0",
            "value": "#e0e0e0"
          },
          "field": "age_std_rate",
          "type": "quantitative",
          "title": "Deaths per 100,000",
          "scale": {
            "scheme": "orangered",
            "domainMin": 0
          },
          "legend": {
            "titleFontSize": 11,
            "labelFontSize": 10,
            "gradientLength": 120
          }
        },
        "tooltip": [
          {
            "field": "remoteness_area",
            "type": "nominal",
            "title": "Remoteness Area"
          },
          {
            "field": "condition",
            "type": "nominal",
            "title": "Condition"
          },
          {
            "field": "age_std_rate",
            "type": "quantitative",
            "title": "Deaths per 100,000",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 10
      },
      "transform": [
        {
          "filter": "isValid(datum.age_std_rate) && datum.age_std_rate !== 0"
        }
      ],
      "encoding": {
        "text": {
          "field": "age_std_rate",
          "type": "quantitative",
          "format": ".1f"
        },
        "color": {
          "condition": {
            "test": "datum.age_std_rate > 50",
            "value": "white"
          },
          "value": "#333333"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#999999"
      },
      "transform": [
        {
          "filter": "!isValid(datum.age_std_rate) || datum.age_std_rate === 0"
        }
      ],
      "encoding": {
        "text": {
          "value": "N/A"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": null,
    "font": "sans-serif"
  },
  "transform": [
    {
      "calculate": "datum.age_std_rate === 0 || datum.age_std_rate === '' ? null : datum.age_std_rate",
      "as": "age_std_rate"
    }
  ]
}
