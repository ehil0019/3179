{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Slope chart: age-standardised death rates by condition across remoteness areas",
  "width": 200,
  "height": 180,
  "data": {
    "url": "data/slope_chart_data.csv"
  },
  "transform": [
    {
      "filter": "datum.age_std_rate > 0"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": false,
        "strokeWidth": 2.5
      },
      "encoding": {
        "x": {
          "field": "remoteness_area",
          "type": "ordinal",
          "title": null,
          "sort": [
            "Major Cities",
            "Inner Regional",
            "Outer Regional",
            "Remote",
            "Very Remote"
          ],
          "axis": {
            "labelFontSize": 11,
            "labelAngle": -20,
            "domainColor": "#ccc",
            "tickColor": "#ccc"
          }
        },
        "y": {
          "field": "age_std_rate",
          "type": "quantitative",
          "title": "Deaths per 100,000 (age-standardised)",
          "axis": {
            "grid": true,
            "gridOpacity": 0.3,
            "labelFontSize": 11,
            "titleFontSize": 12,
            "titleFontWeight": "normal"
          }
        },
        "color": {
          "field": "condition",
          "type": "nominal",
          "title": "Condition",
          "scale": {
            "domain": [
              "CHD",
              "Dementia",
              "Diabetes",
              "Suicide",
              "Accidental falls"
            ],
            "range": [
              "#c0392b",
              "#8e44ad",
              "#e67e22",
              "#2980b9",
              "#27ae60"
            ]
          },
          "legend": {
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "strokeDash": {
          "field": "condition",
          "type": "nominal",
          "scale": {
            "domain": [
              "CHD",
              "Dementia",
              "Diabetes",
              "Suicide",
              "Accidental falls"
            ],
            "range": [
              [
                1,
                0
              ],
              [
                1,
                0
              ],
              [
                1,
                0
              ],
              [
                4,
                2
              ],
              [
                2,
                2
              ]
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "condition",
            "type": "nominal",
            "title": "Condition"
          },
          {
            "field": "remoteness_area",
            "type": "nominal",
            "title": "Remoteness Area"
          },
          {
            "field": "age_std_rate",
            "type": "quantitative",
            "title": "Deaths per 100,000",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 60
      },
      "encoding": {
        "x": {
          "field": "remoteness_area",
          "type": "ordinal",
          "sort": [
            "Major Cities",
            "Inner Regional",
            "Outer Regional",
            "Remote",
            "Very Remote"
          ]
        },
        "y": {
          "field": "age_std_rate",
          "type": "quantitative"
        },
        "color": {
          "field": "condition",
          "type": "nominal",
          "scale": {
            "domain": [
              "CHD",
              "Dementia",
              "Diabetes",
              "Suicide",
              "Accidental falls"
            ],
            "range": [
              "#c0392b",
              "#8e44ad",
              "#e67e22",
              "#2980b9",
              "#27ae60"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "condition",
            "type": "nominal",
            "title": "Condition"
          },
          {
            "field": "remoteness_area",
            "type": "nominal",
            "title": "Remoteness Area"
          },
          {
            "field": "age_std_rate",
            "type": "quantitative",
            "title": "Deaths per 100,000",
            "format": ".1f"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "background": null,
    "font": "sans-serif"
  }
}
