{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Population by Remoteness Area (RA)",

  "data": {
    "url": "data/ra_2021.json",
    "format": {
      "type": "topojson",
      "feature": "RA_2021"
    }
  },

  "transform": [
    {
      "lookup": "properties.ra_name_2021",
      "from": {
        "data": {"url": "data/Population_by_RA.csv"},
        "key": "RA",
        "fields": ["Population"]
      }
    }
  ],

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 0.5
  },

  "encoding": {
    "color": {
      "field": "Population",
      "type": "quantitative",
      "scale": {"scheme": "greens"},
      "title": "Population"
    },
    "tooltip": [
      {"field": "properties.ra_name_2021", "title": "Remoteness Area"},
      {"field": "Population", "title": "Population"}
    ]
  },

  "projection": {"type": "mercator"}
}

