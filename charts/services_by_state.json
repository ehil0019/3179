{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Health Services by State and Service Type",
  "width": 600,
  "height": 400,

  "data": {
    "url": "/data/location_and_type.csv"
  },

  "mark": "bar",

  "encoding": {
    "x": {
      "field": "STATE",
      "type": "nominal",
      "title": "State",
    },

    "y": {
      "aggregate": "count",
      "title": "Number of Services"
    },

    "color": {
      "field": "NHSD_SERVICE_TYPE",
      "type": "nominal",
      "title": "Service Type"
    },

    "tooltip": [
      {"field": "STATE", "title": "State"},
      {"field": "NHSD_SERVICE_TYPE", "title": "Service Type"},
      {"aggregate": "count", "title": "Count"}
    ]
  }
}
