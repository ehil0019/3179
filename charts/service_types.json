{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Proportion of Service Types",

  "data": {
    "url": "data/location_and_type.csv"
  },

  "mark": "rect",

  "encoding": {
    "color": {
      "field": "NHSD_SERVICE_TYPE",
      "type": "nominal",
      "title": "Service Type"
    },

    "size": {
      "aggregate": "count",
      "title": "Number of Services"
    },

    "tooltip": [
      {"field": "NHSD_SERVICE_TYPE", "title": "Service Type"},
      {"aggregate": "count", "title": "Count"}
    ]
  }
}
