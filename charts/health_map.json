{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",

  "layer": [
    {
      "data": {
        "url": "STE_2021_AUST_GDA2020 (1).json",
        "format": {"type": "geojson"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0f0f0",
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "projection": {"type": "mercator"}
    },

    {
      "data": {
        "url": "data/location_and_type.csv"
      },
      "mark": "circle",
      "encoding": {
        "longitude": {"field": "LONGITUDE", "type": "quantitative"},
        "latitude": {"field": "LATITUDE", "type": "quantitative"},
        "color": {"field": "NHSD_SERVICE_TYPE", "type": "nominal"},
        "tooltip": [
          {"field": "ORGANISATION_NAME"},
          {"field": "SUBURB"},
          {"field": "NHSD_SERVICE_TYPE"}
        ]
      }
    }
  ]
}
