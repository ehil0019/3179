{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Health Services Australia",

  "projection": {"type": "mercator"},

  "layer": [
    {
      "data": {
        "url": "data/STE_2021_AUST_GDA2020 (1).json"
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0f0f0",
        "opacity": 0.3,
        "stroke": "white",
        "strokeWidth": 0.5
      }
    },

    {
      "data": {
        "url": "data/location_and_type.csv"
      },
      "mark": "circle",
      "encoding": {
        "longitude": {"field": "LONGITUDE", "type": "quantitative"},
        "latitude": {"field": "LATITUDE", "type": "quantitative"},
        "color": {"field": "GA_CLASS", "type": "nominal"},
        "tooltip": [
          {"field": "ORGANISATION_NAME"},
          {"field": "SUBURB"},
          {"field": "GA_CLASS"}
        ]
      }
    }
  ]
}
