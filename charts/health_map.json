{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Health Services Across Australia",

  "projection": {"type": "mercator"},

  "params": [
    {
      "name": "serviceType",
      "value": "All",
      "bind": {
        "input": "select",
        "options": [
          "All",
          "Primary Care",
          "Child & Family Health",
          "Indigenous Health",
          "Hospital & Emergency",
          "Nursing & Walk-in Care",
          "Other"
        ],
        "name": "Service Type: "
      }
    }
  ],

  "layer": [
    {
      "data": {
        "url": "data/STE_2021.json",
        "format": {
          "type": "topojson",
          "feature": "STE_2021"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0f0f0",
        "opacity": 0.3,
        "stroke": "white",
        "strokeWidth": 0.5
      }
    },

    {
      "data": {
        "url": "data/location_and_type.csv"
      },

      "transform": [
        {
          "calculate": 
            "datum.NHSD_SERVICE_TYPE == 'General practice service' || " +
            "datum.NHSD_SERVICE_TYPE == 'General practice skin cancer service' || " +
            "datum.NHSD_SERVICE_TYPE == 'Medical deputising service' ? 'Primary Care' : " +

            "datum.NHSD_SERVICE_TYPE == 'Maternal, child and family health service' ? 'Child & Family Health' : " +

            "datum.NHSD_SERVICE_TYPE == 'Aboriginal and Torres Strait Islander health service' ? 'Indigenous Health' : " +

            "datum.NHSD_SERVICE_TYPE == 'Hospital service' || " +
            "datum.NHSD_SERVICE_TYPE == 'Hospital general medicine service' || " +
            "datum.NHSD_SERVICE_TYPE == 'Hospital pharmacy service' || " +
            "datum.NHSD_SERVICE_TYPE == 'Hospital-based outpatient clinic' || " +
            "datum.NHSD_SERVICE_TYPE == 'Emergency department service' ? 'Hospital & Emergency' : " +

            "datum.NHSD_SERVICE_TYPE == 'Nurse led clinic' || " +
            "datum.NHSD_SERVICE_TYPE == 'Nurse practitioner led clinic' || " +
            "datum.NHSD_SERVICE_TYPE == 'Walk-in centre' ? 'Nursing & Walk-in Care' : " +

            "'Other'",
          "as": "Service_Group"
        },
        {
          "filter": "serviceType == 'All' || datum.Service_Group == serviceType"
        }
      ],

      "mark": {
        "type": "circle",
        "size": 20,
        "opacity": 0.35,
        "stroke": "white",
        "strokeWidth": 0.3
      },

      "encoding": {
        "longitude": {"field": "LONGITUDE", "type": "quantitative"},
        "latitude": {"field": "LATITUDE", "type": "quantitative"},
        "color": {"field": "Service_Group", "type": "nominal"},
        "tooltip": [
          {"field": "ORGANISATION_NAME"},
          {"field": "SUBURB"},
          {"field": "Service_Group"}
        ]
      }
    }
  ]
}

