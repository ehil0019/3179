{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Distribution of Health Services Across Australia",

  "projection": {"type": "mercator"},

  "params": [
    {
      "name": "serviceType",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All", "Hospital", "GP", "Pharmacy", "Allied Health", "Other"],
        "name": "Service Type: "
      }
    }
  ],

  "layer": [
    {
      "data": {
        "url": "data/STE_2021.json",
        "format": {
          "type": "topojson",
          "feature": "STE_2021"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0f0f0",
        "opacity": 0.3,
        "stroke": "white",
        "strokeWidth": 0.5
      }
    },

    {
      "data": {
        "url": "data/location_and_type.csv"
      },

      "transform": [
        {
          "filter": "serviceType == 'All' || datum.GA_CLASS == serviceType"
        }
      ],

      "mark": {
        "type": "circle",
        "size": 20,
        "opacity": 0.35,
        "stroke": "white",
        "strokeWidth": 0.3
      },

      "encoding": {
        "longitude": {"field": "LONGITUDE", "type": "quantitative"},
        "latitude": {"field": "LATITUDE", "type": "quantitative"},
        "color": {"field": "GA_CLASS", "type": "nominal"},
        "tooltip": [
          {"field": "ORGANISATION_NAME"},
          {"field": "SUBURB"},
          {"field": "GA_CLASS"}
        ]
      }
    }
  ]
}


