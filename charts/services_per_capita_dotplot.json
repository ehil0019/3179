{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Services per 10,000 People by State",

  "data": {
    "url": "data/services_per_capita.csv"
  },

  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#cccccc",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": ["NSW", "VIC", "QLD", "SA", "WA", "TAS", "NT", "ACT"]
        },
        "x": {
          "field": "ServicesPer10k",
          "type": "quantitative"
        },
        "x2": { "value": 0 }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90,
        "color": "#4C6EF5"
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal"
        },
        "x": {
          "field": "ServicesPer10k",
          "type": "quantitative"
        },
        "tooltip": [
          {"field": "State", "title": "State"},
          {"field": "ServicesPer10k", "title": "Services per 10,000"}
        ]
      }
    }
  ]
}
