{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Services per 10,000 People by State",

  "data": {
    "url": "data/location_and_type.csv"
  },

  "transform": [
    {
      "aggregate": [
        {"op": "count", "as": "Services"}
      ],
      "groupby": ["STATE"]
    },
    {
      "lookup": "STATE",
      "from": {
        "data": {"url": "data/population_by_state.csv"},
        "key": "State",
        "fields": ["Population_000"]
      }
    },
    {
      "calculate": "(datum.Services / (datum.Population_000 * 1000)) * 10000",
      "as": "ServicesPer10k"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#cccccc",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": ["NSW","VIC","QLD","SA","WA","TAS","NT","ACT"]
        },
        "x": {
          "field": "ServicesPer10k",
          "type": "quantitative"
        },
        "x2": {"value": 0}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90,
        "color": "#4C6EF5"
      },
      "encoding": {
        "y": {"field": "STATE", "type": "nominal"},
        "x": {"field": "ServicesPer10k", "type": "quantitative"},
        "tooltip": [
          {"field": "STATE", "title": "State"},
          {"field": "Services", "title": "Total Services"},
          {"field": "Population_000", "title": "Population ('000)"},
          {"field": "ServicesPer10k", "title": "Services per 10,000"}
        ]
      }
    }
  ]
}

}
