{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Services per 10,000 People by State",
  "data": {
    "url": "data/services_per_capita.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#cccccc",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "STATE",
          "type": "nominal",
          "sort": ["NSW","VIC","QLD","SA","WA","TAS","NT","ACT"]
        },
        "x": {
          "field": "ServicesPer10k",
          "type": "quantitative"
        },
        "x2": {"value": 0}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 90
      },
      "encoding": {
        "y": {
          "field": "STATE",
          "type": "nominal",
          "sort": ["NSW","VIC","QLD","SA","WA","TAS","NT","ACT"],
          "title": "State"
        },
        "x": {
          "field": "ServicesPer10k",
          "type": "quantitative"
        },
        "color": {
          "field": "STATE",
          "type": "nominal",
          "title": "State / Territory",
          "scale": {
            "domain": ["NSW", "VIC", "QLD", "WA", "SA", "TAS", "NT", "ACT"],
            "range": ["#E69F00", "#56B4E9", "#009E73", "#F0E442", "#0072B2", "#D55E00", "#CC79A7", "#000000"]
          },
          "legend": {
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          {"field": "STATE", "title": "State"},
          {"field": "Services", "title": "Total Services"},
          {"field": "Population_000", "title": "Population ('000)"},
          {"field": "ServicesPer10k", "title": "Services per 10,000"}
        ]
      }
    }
  ]
}

