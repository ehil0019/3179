{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Hospitalisations per 1,000 people by remoteness area, 2013–2024.",
  "width": 600,
  "height": 300,
  "data": {
    "url": "data/Hospitalisation_per_1000_RA.csv"
  },
  "mark": {
    "type": "line",
    "point": {"size": 60},
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "Rate",
      "type": "quantitative",
      "title": "Hospitalisations per 1,000"
    },
    "color": {
      "field": "RA",
      "type": "nominal",
      "title": "Remoteness Area",
      "scale": {
        "scheme": "category10"
      }
    },
    "tooltip": [
      {"field": "Year"},
      {"field": "RA"},
      {"field": "Rate"}
    ]
  }
}
