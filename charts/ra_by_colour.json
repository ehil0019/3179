{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Remoteness Areas of Australia (RA 2021)",

  "width": 800,
  "height": 600,

  "data": {
    "url": "data/ra_2021.geojson",
    "format": {
      "type": "topojson",
      "feature": "RA_2021_AUST_GDA94"
    }
  },

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 0.5
  },

  "encoding": {
    "color": {
      "field": "RA_NAME21",
      "type": "nominal",
      "title": "Remoteness Area",
      "scale": {"scheme": "tableau10"}
    }
  },

  "projection": {"type": "mercator"}
}
