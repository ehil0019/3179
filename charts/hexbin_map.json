{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 900,
  "height": 900,
  "projection": {"type": "mercator"},
  "data": {
    "url": "hexbin_services.geojson",
    "format": {"type": "geojson"}
  },
  "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.3},
  "encoding": {
    "color": {
      "field": "properties.count",
      "type": "quantitative",
      "scale": {
        "type": "linear",
        "range": ["#f2e5ff", "#d4b3ff", "#b380ff", "#914dff", "#6f00ff"]
      },
      "legend": {
        "title": "Number of Services",
        "orient": "right"
      }
    },
    "tooltip": [
      {"field": "properties.count", "type": "quantitative", "title": "Services in Hex"}
    ]
  }
}


