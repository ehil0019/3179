{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Distribution of Health Services Across Australia",

  "width": "container",
  "height": 600,

  "projection": {"type": "mercator"},

  "layer": [
    {
      "data": {
        "url": "data/STE_2021.json",
        "format": {"type": "topojson", "feature": "STE_2021_AUST"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f7f7f7",
        "stroke": "#cccccc"
      }
    },

    {
      "data": {
        "url": "data/services_with_counts.csv"
      },

      "mark": {
        "type": "circle",
        "opacity": 0.7,
        "stroke": "white",
        "strokeWidth": 0.5
      },

      "encoding": {
        "longitude": {"field": "LONGITUDE", "type": "quantitative"},
        "latitude": {"field": "LATITUDE", "type": "quantitative"},

        "size": {
          "field": "Services",
          "type": "quantitative",
          "scale": {"range": [20, 1200]},
          "title": "Services in Suburb"
        },

        "color": {
          "field": "NHSD_SERVICE_TYPE",
          "type": "nominal",
          "scale": {
            "domain": [
              "General Practice",
              "Pharmacy",
              "Hospital",
              "Clinic",
              "Other"
            ],
            "range": [
              "#1b9e77",
              "#d95f02",
              "#7570b3",
              "#e7298a",
              "#66a61e"
            ]
          },
          "title": "Service Type"
        },

        "tooltip": [
          {"field": "ORGANISATION_NAME", "title": "Organisation"},
          {"field": "SUBURB", "title": "Suburb"},
          {"field": "NHSD_SERVICE_TYPE", "title": "Service Type"},
          {"field": "Services", "title": "Services in Suburb"}
        ]
      }
    }
  ]
}
